br><span class="line">    IT0=1; //(外0)&quot;0&quot;低电平有效，&quot;1&quot;下降沿有效</span><br><span class="line">    EX1=1; //外1可以外部中断</span><br><span class="line">    IT1=1; //(外1)&quot;0&quot;低电平有效，&quot;1&quot;下降沿有效</span><br><span class="line">    while(1);</span><br><span class="line">&#125;</span><br><span class="line"></span><br><span class="line">it0() interrupt 0 &#123;</span><br><span class="line">while(1) &#123;</span><br><span class="line">        for(i=0; i&lt;8; i++)</span><br><span class="line">        &#123;</span><br><span class="line">            P1=~(0x01&lt;&lt;i);</span><br><span class="line">            yc(500);</span><br><span class="line">            if(IE1==1)break; //如果代码收到外1中断申请跳出该循环</span><br><span class="line">        &#125;</span><br><span class="line">    if(IE1==1)break; //如果代码收到外1中断申请跳出该循环</span><br><span class="line">        &#125;</span><br><span class="line">&#125;</span><br><span class="line">it2() interrupt 2 &#123;</span><br><span class="line">while(1) &#123;</span><br><span class="line">        for(i=0; i&lt;8; i++)</span><br><span class="line">        &#123;</span><br><span class="line">            P1=~(0x80&gt;&gt;i);</span><br><span class="line">            yc(500);</span><br><span class="line">            if(IE1==1)break; //如果代码收到外0中断申请跳出该循环</span><br><span class="line">        &#125;</span><br><span class="line">    if(IE0==1)break; //如果代码收到外0中断申请跳出该循环</span><br><span class="line">        &#125;</span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>]]></content>
      
      
